# Base URL for the istudy-cms API. Dev defaults to http://localhost:3131;
# production should point at the deployed CMS origin.
NEXT_PUBLIC_CMS_URL=http://localhost:3131

# Branding domain rendered in footer / watermark / SEO metadata.
NEXT_PUBLIC_DOMAIN=aistudy.com.vn

# Giscus drop-in (https://giscus.app). Fill these once the GitHub repo is
# created + Discussions enabled. The Comments component renders nothing
# until all four values are present.
NEXT_PUBLIC_GISCUS_REPO=istudy/comments-discussions
NEXT_PUBLIC_GISCUS_REPO_ID=
NEXT_PUBLIC_GISCUS_CATEGORY=Bài viết
NEXT_PUBLIC_GISCUS_CATEGORY_ID=

# Cloudflare Turnstile captcha for email subscription.
# Test key: 1x00000000000000000000AA (always passes in dev).
NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA

# Google AdSense client ID for banner/in-content ads.
NEXT_PUBLIC_ADSENSE_CLIENT_ID=ca-pub-0000000000000000
